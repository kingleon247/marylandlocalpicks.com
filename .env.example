# Set to true to show the coming-soon gate unless the visitor has review access.
SITE_GATE_ENABLED=false

# Private preview passcode (server-side only — do not use NEXT_PUBLIC_).
SITE_GATE_PASSCODE=change-me

# --- Vapi AI voice (inbound advertiser phone assistant) ---
# Shared secret used to authenticate incoming Vapi webhook requests.
# Set the same value in the Vapi dashboard (Server URL secret). Leave blank in
# local dev to allow unauthenticated requests with a warning. See
# _docs/vapi-voice-setup.md.
VAPI_WEBHOOK_SECRET=

# The Vapi assistant id that answers inbound advertiser calls. Used to respond
# to "assistant-request" webhook events when present.
VAPI_ASSISTANT_ID=

# The public advertiser phone number connected to Vapi, in E.164 format.
# Display: 443-94-PICKS · (443) 947-4257
VAPI_PHONE_NUMBER=+14439474257

# Optional internal address to notify on new voice leads. Leave blank/unused
# until email notifications are wired up.
MLP_INTERNAL_NOTIFY_EMAIL=
